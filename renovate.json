{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/ci\\.yml$"],
      "matchStrings": ["NODE_VERSION:\\s*(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["node"],
      "groupName": "node version",
      "description": "Group all node version bumps into a single PR"
    }
  ]
}
