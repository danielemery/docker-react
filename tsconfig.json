{
  "compilerOptions": {
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2024",
    "outDir": "./dist",
    "rootDir": "./cli",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["node"]
  },
  "include": ["./cli"]
}
